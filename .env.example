# Auth: pick ONE method

# Option 1: Gemini API key (local dev)
# GEMINI_API_KEY=your_gemini_api_key_here

# Option 2: ADC / Vertex AI (GCE, Cloud Run — uses attached service account)
GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# Image generation model (default: gemini-3-pro-image-preview)
# IMAGE_MODEL_ID=gemini-3-pro-image-preview

# Text/intelligence model (default: gemini-2.5-flash)
# TEXT_MODEL_ID=gemini-2.5-flash

# Optional: Supabase integration (currently only used for configuration checks)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
