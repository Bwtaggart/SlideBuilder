#!/usr/bin/env zsh
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
PID_FILE="$ROOT_DIR/.slidebuilder.pid"
LOG_FILE="$ROOT_DIR/.slidebuilder.log"
PORT="${PORT:-3030}"

if [[ -f "$PID_FILE" ]]; then
  EXISTING_PID="$(cat "$PID_FILE" 2>/dev/null || true)"
  if [[ -n "${EXISTING_PID}" ]] && kill -0 "$EXISTING_PID" 2>/dev/null; then
    echo "SlideBuilder already running on http://localhost:${PORT} (PID: ${EXISTING_PID})"
    exit 0
  fi
  rm -f "$PID_FILE"
fi

if lsof -ti :"$PORT" >/dev/null 2>&1; then
  echo "Port ${PORT} is already in use. Stop that process or run with a different PORT."
  exit 1
fi

cd "$ROOT_DIR"
nohup npm run dev -- -p "$PORT" >>"$LOG_FILE" 2>&1 &
NEW_PID=$!
echo "$NEW_PID" >"$PID_FILE"

echo "SlideBuilder started on http://localhost:${PORT} (PID: ${NEW_PID})"
echo "Logs: $LOG_FILE"
