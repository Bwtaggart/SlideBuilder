{
  "name": "slidebuilder-temp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "slides-up": "next dev -p 3000 > /tmp/slidebuilder.log 2>&1 & echo \"SlideBuilder started on http://localhost:3000 (PID: $!)\"",
    "slides-down": "pids=$(lsof -ti :3000); if [ -n \"$pids\" ]; then echo \"$pids\" | xargs kill -9 && echo 'SlideBuilder stopped'; else echo 'Not running'; fi",
    "slides-logs": "tail -f /tmp/slidebuilder.log"
  },
  "dependencies": {
    "@google/genai": "^1.42.0",
    "@supabase/supabase-js": "^2.97.0",
    "file-saver": "^2.0.5",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "pptxgenjs": "^4.0.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
